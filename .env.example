# Convex — URL from `npx convex dev` / dashboard (must match deployment you use in prod)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Same strings in Convex dashboard (Settings → Environment) for backend auth
DASHBOARD_SECRET=long-random-string
INGEST_SECRET=another-long-random-string

# Convex dashboard only (not in .env.local for serverless security preference)
OPENAI_API_KEY=
# Optional (Convex dashboard)
# OPENAI_VISION_MODEL=gpt-4o

# Telegram — Next.js / Vercel (webhook runs on this app)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=random-token-matching-setWebhook-secret_token

# HTTPS origin of this app, no trailing slash — used by: npm run telegram:set-webhook
PUBLIC_APP_URL=https://your-app.vercel.app
